# Configuration ESP32 - OBLIGATOIRE
ESP32_URL=http://192.168.1.100:80
ESP32_LOCAL_IP=192.168.1.100

# Configuration tunnel pour accès distant - OPTIONNEL
NGROK_TOKEN=your_ngrok_token_here
TUNNEL_URL=https://your-tunnel-url.ngrok.io

# Configuration sécurité - OPTIONNEL
JWT_SECRET=your_jwt_secret_here
API_KEY=your_api_key_here

# Mode de développement
NODE_ENV=development

# Configuration Next.js
NEXT_PUBLIC_ESP32_URL=http://192.168.1.100:80